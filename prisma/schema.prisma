generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  passwordHash  String
  companyName   String?
  role          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  settings       UserSettings?
  smtpAccount    SmtpAccount?
  leads          Lead[]
  campaigns      Campaign[]
  emailSequences EmailSequence[]
  smsSequences   SmsSequence[]
  replies        Reply[]
  bookedCalls    BookedCall[]
  activityLogs   ActivityLog[]
  unsubscribeList UnsubscribeList[]
  candidates     Candidate[]
  candidateSearches CandidateSearch[]

  candidateProfiles CandidateProfile[]
  resumes           Resume[]
  savedJobs         SavedJob[]
  jobApplications   JobApplication[]
  jobSearchHistory  JobSearchHistory[]
  aiJobAnalyses     AIJobAnalysis[]
  apiUsages         APIUsage[]
  companyFilterPresets CompanyFilterPreset[]
}

model UserSettings {
  id                       String   @id @default(uuid())
  userId                   String   @unique
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  apifyTokenEncrypted      String?
  openrouterKeyEncrypted   String?
  openrouterModel          String?
  
  twilioSidEncrypted       String?
  twilioAuthTokenEncrypted String?
  twilioPhone              String?
  
  smtpHost                 String?
  smtpPort                 String?
  smtpUserEncrypted        String?
  smtpPassEncrypted        String?
  smtpFromName             String?
  smtpFromEmail            String?
  
  bookingLink              String?
  
  dailyEmailLimit          Int      @default(100)
  emailDelaySeconds        Int      @default(30)
  smsDelaySeconds          Int      @default(15)
  defaultCountry           String?
  defaultCampaignGoal      String?
  
  manualApprovalMode       Boolean  @default(true)
  autoSendMode             Boolean  @default(false)
  
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Lead {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  campaignId      String?
  campaign        Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  companyId       String?
  company         Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  businessName    String
  phone           String?
  email           String?
  website         String?
  address         String?
  rating          Float?
  reviewCount     Int?
  googleMapsLink  String?
  category        String?
  country         String?
  location        String?
  
  leadScore       Int      @default(0)
  leadTier        String   @default("Cold") // Hot, Warm, Cold
  aiInsight       String?
  
  source          String   @default("Apify")
  status          String   @default("New") // New, Added to Campaign, Email Generated, Email Sent, SMS Sent, Replied, Interested, Not Interested, Call Booked, Closed, Unsubscribed
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  campaignLeads   CampaignLead[]
  emailSequences  EmailSequence[]
  smsSequences    SmsSequence[]
  replies         Reply[]
  bookedCalls     BookedCall[]
  activityLogs    ActivityLog[]
  emailSendLogs   EmailSendLog[]
  emailReplies    EmailReply[]
}

model Campaign {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name               String
  goal               String?
  businessType       String?
  location           String?
  country            String?
  
  campaignType       String?
  targetAudience     String?
  industry           String?
  offer              String?
  tone               String?
  language           String?
  ctaType            String?
  ctaLink            String?
  senderName         String?
  agencyName         String?
  emailSignature     String?
  sendingMode        String   @default("Human Approval Mode")
  
  status             String   @default("Draft") // Draft, Active, Paused, Completed, Stopped
  bookingLink        String?
  
  // 7-step sequence & AI timing settings
  followUpCount               Int      @default(7)
  timingMode                  String   @default("AI Recommended")
  timezoneMode                String   @default("Recipient Local Time")
  allowedSendingDays          String?  // JSON e.g. ["Mon","Tue","Wed","Thu","Fri"]
  sendingWindowStart          String?  @default("09:00")
  sendingWindowEnd            String?  @default("16:00")
  weekendsEnabled             Boolean  @default(false)
  skipHolidays                Boolean  @default(true)
  autoApproveEmails           Boolean  @default(false)
  autoSendApprovedEmails      Boolean  @default(false)
  bookingAutomationMode       String   @default("Manual Booking")
  meetingType                 String?
  meetingDuration             Int      @default(30)
  minimumBookingNotice        Int      @default(24) // hours
  maximumBookingHorizon       Int      @default(14) // days
  autoCreateCalendarEvent     Boolean  @default(false)
  autoSendBookingConfirmation Boolean  @default(false)
  knowledgeBaseMode           String   @default("Use All Knowledge Base Files")
  selectedKnowledgeBaseFileIds String? // JSON

  emailSequenceCount Int      @default(0)
  smsSequenceCount   Int      @default(0)
  
  dailyLimit         Int?
  sendDelaySeconds   Int?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  leads              Lead[]
  campaignLeads      CampaignLead[]
  emailSequences     EmailSequence[]
  smsSequences       SmsSequence[]
  replies            Reply[]
  bookedCalls        BookedCall[]
  activityLogs       ActivityLog[]
  emailSendLogs      EmailSendLog[]
  emailReplies       EmailReply[]
}

model CampaignLead {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  status     String   @default("Pending")
  addedAt    DateTime @default(now())

  @@unique([campaignId, leadId])
}

model EmailSequence {
  id                  String   @id @default(uuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId          String
  campaign            Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadId              String
  lead                Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  name                String?
  subject             String
  previewText         String?
  body                String
  sequenceStep        Int
  
  ctaText             String?
  ctaLink             String?
  delayAmount         Int      @default(0)
  delayUnit           String   @default("business_days")
  
  status              String   @default("Draft") // Draft, Scheduled, Sent, Failed
  approvalStatus      String   @default("Pending") // Pending, Approved, Rejected
  
  aiOriginalSubject   String?
  aiOriginalBody      String?
  editedSubject       String?
  editedBody          String?
  personalizationData String?  // JSON string
  aiGenerationReason  String?
  personalizationScore Int?
  spamRisk            String?
  
  scheduledAt         DateTime?
  scheduledTimezone   String?
  recommendedSendAt   DateTime?
  timingReason        String?
  knowledgeBaseSources String? // JSON
  personalizationReason String?
  skippedAt           DateTime?
  stoppedAt           DateTime?
  sentAt              DateTime?
  approvedAt          DateTime?
  replyReceived       Boolean  @default(false)
  errorMessage        String?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  emailSendLogs       EmailSendLog[]
}

model SmsSequence {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId    String
  campaign      Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadId        String
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  message       String
  sequenceStep  Int
  
  status        String   @default("Draft") // Draft, Approved, Scheduled, Sent, Failed
  scheduledAt   DateTime?
  sentAt        DateTime?
  replyReceived Boolean  @default(false)
  errorMessage  String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Reply {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId           String
  lead             Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaignId       String?
  campaign         Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  
  channel          String // Email, SMS
  messageBody      String
  intent           String? // Interested, Not Interested, Objection, etc.
  aiSuggestedReply String?
  status           String   @default("Unread") // Unread, Handled, Ignored
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model BookedCall {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId             String
  lead               Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaignId         String?
  campaign           Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  
  callDate           DateTime?
  bookingLink        String?
  status             String   @default("Scheduled") // Scheduled, Completed, Canceled
  notes              String?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  
  activityType String
  description  String
  metadata     String? // JSON string
  
  createdAt    DateTime @default(now())
}

model SmtpAccount {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  smtpHost           String
  smtpPort           Int
  smtpUserEncrypted  String
  smtpPassEncrypted  String
  fromName           String
  fromEmail          String
  replyToEmail       String?
  
  status             String   @default("Active") // Active, Failed
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model EmailSendLog {
  id              String   @id @default(uuid())
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  emailSequenceId String
  emailSequence   EmailSequence @relation(fields: [emailSequenceId], references: [id], onDelete: Cascade)
  
  subject         String
  body            String
  
  status          String   @default("Sent") // Sent, Failed, Bounced
  
  sentAt          DateTime @default(now())
  openedAt        DateTime?
  clickedAt       DateTime?
  bouncedAt       DateTime?
  errorMessage    String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model EmailReply {
  id                String   @id @default(uuid())
  campaignId        String?
  campaign          Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  leadId            String
  lead              Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  emailBody         String
  aiCategory        String?
  aiSuggestedReply  String?
  recommendedAction String?
  shouldAutoSend    Boolean  @default(false)
  
  status            String   @default("Unread") // Unread, Handled, Ignored
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model UnsubscribeList {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email       String
  reason      String?
  
  createdAt   DateTime @default(now())
  
  @@unique([userId, email])
}

model Candidate {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  jobTitle    String?
  email       String?
  phone       String?
  location    String?
  country     String?
  skills      String?
  experience  String?
  profileUrl  String?
  resumeUrl   String?
  
  source      String   @default("Job Board API")
  matchScore  Int?
  aiSummary   String?
  status      String   @default("New")
  rawData     String? // JSON string
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CandidateSearch {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  jobTitle        String?
  skills          String?
  location        String?
  country         String?
  experienceLevel String?
  maxResults      Int      @default(10)
  totalFound      Int      @default(0)
  status          String   @default("Completed")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CandidateProfile {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  firstName         String
  lastName          String
  email             String?
  phone             String?
  city              String?
  country           String?
  currentJobTitle   String?
  desiredJobTitle   String?
  skills            String?
  yearsOfExperience String?
  education         String?
  certifications    String?
  preferredWorkMode String?
  preferredJobTypes String?
  minimumSalary     String?
  preferredLocations String?
  profileSummary    String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  resumes           Resume[]
  jobApplications   JobApplication[]
  aiJobAnalyses     AIJobAnalysis[]
}

model Resume {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidateProfileId String?
  candidateProfile  CandidateProfile? @relation(fields: [candidateProfileId], references: [id], onDelete: SetNull)
  
  fileName          String
  fileType          String
  fileSize          Int
  storagePath       String
  extractedText     String?
  structuredData    String?  // JSON
  status            String   @default("Pending")
  errorMessage      String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Company {
  id                       String   @id @default(uuid())
  externalId               String?  @unique
  name                     String
  website                  String?
  location                 String?
  country                  String?
  activeJobPostCount       Int      @default(0)
  recentJobPostCount       Int      @default(0)
  recentJobPostCount7Days  Int      @default(0)
  recentJobPostCount30Days Int      @default(0)
  latestPostingDate        DateTime?
  hiringActivity           String?
  hiringDemand             String?
  aiHiringInsight          String?
  source                   String   @default("Adzuna")
  rawData                  String?  // JSON
  
  archived                 Boolean  @default(false)
  archivedAt               DateTime?
  archivedBy               String?
  archiveReason            String?

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  jobs                     Job[]
  leads                    Lead[]
}

model Job {
  id                 String   @id @default(uuid())
  externalId         String?  @unique
  companyId          String?
  company            Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  
  source             String   @default("Adzuna")
  title              String
  category           String?
  description        String?
  location           String?
  city               String?
  region             String?
  country            String?
  latitude           Float?
  longitude          Float?
  workMode           String?
  jobType            String?
  contractType       String?
  contractTime       String?
  salaryMin          Float?
  salaryMax          Float?
  salaryCurrency     String?
  salaryDisclosed    Boolean  @default(false)
  requiredExperience String?
  requiredSkills     String?
  preferredSkills    String?
  datePosted         DateTime?
  applicationUrl     String?
  companyWebsite     String?
  
  vacancies          Int?
  candidatesNeeded   Int?
  vacancyStatus      String?
  vacancyEvidence    String?
  hiringUrgency      String?
  hiringDemand       String?
  
  aiSummary          String?
  rawData            String?  // JSON
  descriptionHash    String?
  
  firstSeenAt        DateTime @default(now())
  lastSeenAt         DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  savedJobs          SavedJob[]
  jobApplications    JobApplication[]
  aiJobAnalyses      AIJobAnalysis[]
}

model SavedJob {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  notes       String?
  tags        String?
  priority    String   @default("Medium")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, jobId])
}

model JobApplication {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidateProfileId String?
  candidateProfile   CandidateProfile? @relation(fields: [candidateProfileId], references: [id], onDelete: SetNull)
  jobId              String
  job                Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  status             String   @default("Applied") // Saved, Applied, Interview, Rejected, Offer Received, Hired, Withdrawn
  applicationDate    DateTime?
  interviewDate      DateTime?
  notes              String?
  applicationMessage String?
  coverLetter        String?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model JobSearchHistory {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  searchFilters  String?  // JSON
  countryCode    String?
  totalResults   Int      @default(0)
  
  createdAt      DateTime @default(now())
}

model AIJobAnalysis {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId              String
  job                Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateProfileId String?
  candidateProfile   CandidateProfile? @relation(fields: [candidateProfileId], references: [id], onDelete: SetNull)
  
  summary            String?
  requiredSkills     String?  // JSON array
  preferredSkills    String?  // JSON array
  requiredExperience String?
  workMode           String?
  jobType            String?
  vacancies          Int?
  candidatesNeeded   Int?
  vacancyStatus      String?
  vacancyEvidence    String?
  hiringUrgency      String?
  hiringDemand       String?
  
  matchScore         Float?
  matchingSkills     String?  // JSON array
  missingSkills      String?  // JSON array
  matchReason        String?
  applicationMessage String?
  coverLetter        String?
  
  model              String?
  status             String   @default("Completed")
  errorMessage       String?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model APIUsage {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      String   // Adzuna, OpenRouter
  endpoint      String?
  requestCount  Int      @default(1)
  tokenUsage    Int      @default(0)
  estimatedCost Float    @default(0.0)
  status        String   @default("Success")
  
  createdAt     DateTime @default(now())
}

model SchedulingDecision {
  id               String   @id @default(uuid())
  userId           String
  campaignId       String
  leadId           String?
  candidateId      String?
  emailSequenceId  String
  recommendedSendAt DateTime
  finalSendAt      DateTime?
  timezone         String
  reason           String?
  source           String // AI or Human
  userModified     Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AIActionLog {
  id            String   @id @default(uuid())
  userId        String
  campaignId    String?
  leadId        String?
  candidateId   String?
  actionType    String
  decision      String
  riskLevel     String   @default("Low")
  inputSummary  String?  // JSON
  outputSummary String?  // JSON
  status        String   @default("Completed")
  createdAt     DateTime @default(now())
}

model CompanyFilterPreset {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  description String?
  filters     String   // JSON string
  isDefault   Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

